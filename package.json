{
  "name": "nanoclaw",
  "version": "1.0.0",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "update": "git pull && npm install && npm run build && systemctl --user restart nanoclaw",
    "start": "node dist/index.js",
    "dev": "LOG_LEVEL=debug tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "add-channel": "tsx scripts/add-channel.ts",
    "generate": "cd ./src/db/main && drizzle-kit generate && cd ../sessions && drizzle-kit generate && cd ../../../",
    "migrate": "cd ./src/db/main && drizzle-kit migrate && cd ../sessions && drizzle-kit migrate && cd ../../../",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.35",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@chat-adapter/discord": "^4.14.0",
    "@libsql/client": "^0.17.0",
    "ai": "^6.0.97",
    "better-sqlite3": "^11.8.1",
    "chat": "^4.14.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fast-glob": "^3.3.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
