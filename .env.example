

# Added by skill
DISCORD_BOT_TOKEN=
DISCORD_ONLY=

# PostHog Analytics (optional)
# Get your project API key from https://us.posthog.com/project/settings
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Logging Configuration
# LOG_LEVEL=debug enables dev mode (logs to files + pretty console)
# When not in dev mode and PostHog is configured, logs go to PostHog
# When not in dev mode and PostHog is NOT configured, logs go to files only
LOG_LEVEL=info
